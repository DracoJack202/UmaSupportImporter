{
  "manifest_version": 3,
  "name": "Bonus Table Extractor",
  "version": "1.0",
  "description": "Extract and copy CSV",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Copiar CSV"
  },
  "content_scripts": [
    {
      "matches": ["https://gametora.com/umamusume/compare"],
      "js": ["content.js"]
    }
  ]
}
